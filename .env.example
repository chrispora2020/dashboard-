# ─── Base de datos ────────────────────────────────────────────────────────────
# Neon (producción / staging): obtener desde https://console.neon.tech
#   Connection string → postgresql+psycopg2://<user>:<password>@<host>/<dbname>?sslmode=require
# Docker Compose (local): postgresql+psycopg2://appuser:secret@postgres:5432/kpi_db
DATABASE_URL=postgresql+psycopg2://appuser:secret@postgres:5432/kpi_db

# ─── Redis ────────────────────────────────────────────────────────────────────
# Upstash (producción / staging): obtener desde https://console.upstash.com
#   Connection string → rediss://default:<password>@<host>:<port>
# Docker Compose (local): redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# ─── Autenticación ────────────────────────────────────────────────────────────
JWT_SECRET=supersecretkey

# ─── Rutas internas (Docker Compose) ──────────────────────────────────────────
UPLOAD_DIR=/data/uploads
BACKEND_INTERNAL_URL=http://backend:8000

# ─── IA (Google AI Studio / Gemini) ──────────────────────────────────────────
# Crea tu clave en: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
